{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "instruction": {
      "type": "string",
      "description": "Detailed instruction for tonoben to execute"
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Priority level of the instruction"
    },
    "expected_outcome": {
      "type": "string",
      "description": "Expected outcome or result"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or considerations"
    }
  },
  "required": ["instruction"],
  "additionalProperties": false
}
